    "socialNetwork": {
      "type": "enumeration",
      "enum": [
        "Facebook",
        "Twitter"
      ],
      "required": true
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 60
    },
    "description": {
      "type": "text",
      "required": true,
      "maxLength": 65
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
